# ==========================================
# TTS SaaS - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values

# ------------------------------------------
# Database (MySQL 8)
# ------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=tts_saas
MYSQL_USER=tts_user
MYSQL_PASSWORD=tts_password
MYSQL_PORT=3306
MYSQL_HOST=localhost

DATABASE_URL=mysql://tts_user:tts_password@localhost:3306/tts_saas

# ------------------------------------------
# Redis
# ------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# ------------------------------------------
# Application
# ------------------------------------------
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ------------------------------------------
# JWT Auth
# ------------------------------------------
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------
# Stripe (Payments)
# ------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# ------------------------------------------
# TTS Provider Keys
# ------------------------------------------
# Add your TTS engine API keys here
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_CREDENTIALS_JSON=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ------------------------------------------
# Adminer (DB GUI)
# ------------------------------------------
ADMINER_PORT=8080

# ------------------------------------------
# Email (Transactional)
# ------------------------------------------
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
